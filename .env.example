# ---------------------------------------------------------------------------
# Copy this file to .env.local for local development.
# On Netlify: Site settings -> Environment variables -> add every value below.
# Never commit the real .env.local file (it's already in .gitignore).
# ---------------------------------------------------------------------------

# --- Branding (safe to expose to the browser) --------------------------------
# Change this to whatever you land on. It is the ONLY place the brand name
# lives, so renaming the whole app is a one-line change. Pick something that
# is not confusingly similar to an existing IELTS-prep brand.
NEXT_PUBLIC_APP_NAME="SpeakScore BD"

# The canonical URL of your deployed site (no trailing slash). Used to build
# the Google OAuth redirect and absolute links in emails if you add them later.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Project Settings -> API) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Called the "anon" key in older Supabase dashboards, "publishable" key in newer ones.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
# SECRET. Server-only. Bypasses Row Level Security - never expose to the client.
# Used only by the admin approve/reject routes and the audio-analysis route.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Google Gemini (https://aistudio.google.com/apikey) ----------------------
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# gemini-1.5-* models have been fully retired by Google. gemini-2.5-flash is the
# current cost-effective default. Swap to gemini-3.5-flash or gemini-3.1-pro (or
# whatever is newest when you read this) for higher-quality scoring at a higher
# per-request cost - see README.md for the trade-off.
GEMINI_MODEL="gemini-2.5-flash"

# --- Free trial limit --------------------------------------------------------
# Mirrors the default in the `profiles.free_tries_limit` DB column. Changing
# this only affects newly-created profiles; existing users keep their own limit.
NEXT_PUBLIC_FREE_TRIES_LIMIT="2"

# --- Manual bKash / Nagad payment details ------------------------------------
NEXT_PUBLIC_PREMIUM_PRICE_BDT="200"
NEXT_PUBLIC_BKASH_NUMBER="01XXXXXXXXX"
NEXT_PUBLIC_BKASH_TYPE="Personal (Send Money)"
NEXT_PUBLIC_NAGAD_NUMBER="01XXXXXXXXX"
NEXT_PUBLIC_NAGAD_TYPE="Personal (Send Money)"

# --- Admin panel (owner-only, shared-password gate) --------------------------
# SECRET. Choose a long, random password - anyone who has it can approve
# payments and grant premium access.
ADMIN_PASSWORD="choose-a-long-random-password"
# SECRET. Random string (32+ chars) used to sign the admin session cookie.
# Generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET="generate-a-random-32-byte-secret"
